# ─── Firebase / Firestore Data Sync ────────────────────────────────────────────
# Set these variables to enable real-time data sync (Firestore onSnapshot) across
# all devices. Create a Firebase project at https://console.firebase.google.com/
# and add a Web app to get the config values below.
#
# Steps:
# 1. Go to https://console.firebase.google.com/ → create / select your project
# 2. Project Settings → General → Your apps → Web app → copy the config values
# 3. Firestore Database → Create database (start in production mode)
# 4. Firestore Rules → allow read/write for authenticated access or use the
#    simple open rule during testing:
#      rules_version = '2';
#      service cloud.firestore {
#        match /databases/{database}/documents {
#          match /{document=**} { allow read, write: if true; }
#        }
#      }
# 5. Set the env vars below in Vercel (Settings → Environment Variables),
#    then redeploy.

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Optional: Firestore collection and document to store state in.
# Defaults to collection "shg-bank", document "state".
# VITE_FIREBASE_COLLECTION=shg-bank
# VITE_FIREBASE_DOC_ID=state

# ─── Generic REST Sync (Advanced / Alternative) ────────────────────────────────
# If you prefer a different backend (e.g. a custom API), set these instead.
# VITE_SHARED_STATE_URL=https://your-api-endpoint.example.com/state
# VITE_SHARED_STATE_TOKEN=your_bearer_token_here
# VITE_SHARED_STATE_METHOD=PUT
